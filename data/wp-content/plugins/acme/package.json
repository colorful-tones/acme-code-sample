{
	"name": "@acme/plugin",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"build": "wp-scripts build",
		"start": "wp-scripts start",
		"format": "npm run format:js && npm run format:css",
		"format:css": "stylelint \"**/*.scss\" --fix",
		"format:js": "wp-scripts lint-js --fix",
		"lint": "npm run lint:js && npm run lint:css",
		"lint:js": "wp-scripts lint-js --max-warnings=0",
		"lint:css": "stylelint \"**/*.scss\" --max-warnings=0",
		"lint:js:fix": "wp-scripts lint-js --fix",
		"packages-update": "wp-scripts packages-update"
	},
	"devDependencies": {
		"@wordpress/prettier-config": "^4.35.0",
		"@wordpress/scripts": "^32.2.0",
		"@wordpress/stylelint-config": "^23.27.0",
		"eslint-config-prettier": "^8.10.2",
		"prop-types": "^15.8.1",
		"stylelint": "^16.26.0",
		"webpack-remove-empty-scripts": "^1.1.1"
	},
	"dependencies": {
		"@wordpress/api-fetch": "^7.46.0",
		"@wordpress/block-editor": "^15.19.0",
		"@wordpress/blocks": "^15.19.0",
		"@wordpress/components": "^33.1.0",
		"@wordpress/compose": "^7.46.0",
		"@wordpress/core-data": "^7.46.0",
		"@wordpress/data": "^10.46.0",
		"@wordpress/element": "^6.46.0",
		"@wordpress/hooks": "^4.46.0",
		"@wordpress/i18n": "^6.19.0",
		"@wordpress/icons": "^13.1.0",
		"@wordpress/rich-text": "^7.46.0",
		"copy-webpack-plugin": "^10.2.4"
	}
}
