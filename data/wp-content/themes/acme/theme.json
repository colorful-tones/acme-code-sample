{
	"$schema": "https://schemas.wp.org/wp/7.0/theme.json",
	"version": 3,
	"customTemplates": [
		{
			"name": "page-with-recent-posts",
			"postTypes": [
				"post",
				"page"
			],
			"title": "Page (With Recent Posts)"
		}
	],
	"settings": {
		"appearanceTools": true,
		"color": {
			"custom": true,
			"customDuotone": false,
			"customGradient": false,
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"duotone": [],
			"gradients": [],
			"palette": [
				{
					"color": "#113409",
					"name": "Primary",
					"slug": "primary"
				},
				{
					"color": "#2c8a19",
					"name": "Primary 100",
					"slug": "primary-100"
				},
				{
					"color": "#4cd930",
					"name": "Primary 200",
					"slug": "primary-200"
				},
				{
					"color": "#180934",
					"name": "Secondary",
					"slug": "secondary"
				},
				{
					"color": "#3f198a",
					"name": "Secondary 100",
					"slug": "secondary-100"
				},
				{
					"color": "#6830d9",
					"name": "Secondary 200",
					"slug": "secondary-200"
				},
				{
					"color": "#340926",
					"name": "Accent",
					"slug": "accent"
				},
				{
					"color": "#8a1964",
					"name": "Accent 100",
					"slug": "accent-100"
				},
				{
					"color": "#d930a1",
					"name": "Accent 200",
					"slug": "accent-200"
				},
				{
					"color": "#17191c",
					"name": "Neutral 0",
					"slug": "neutral-0"
				},
				{
					"color": "#3c4048",
					"name": "Neutral 100",
					"slug": "neutral-100"
				},
				{
					"color": "#6b7280",
					"name": "Neutral 200",
					"slug": "neutral-200"
				},
				{
					"color": "#a0a6b0",
					"name": "Neutral 300",
					"slug": "neutral-300"
				},
				{
					"color": "#d8dadf",
					"name": "Neutral 400",
					"slug": "neutral-400"
				},
				{
					"color": "#F2F3F4",
					"name": "Neutral 500",
					"slug": "neutral-500"
				},
				{
					"color": "#000000",
					"name": "Black",
					"slug": "black"
				},
				{
					"color": "#00000080",
					"name": "Black 50",
					"slug": "black-50"
				},
				{
					"color": "#ffffff",
					"name": "White",
					"slug": "white"
				}
			]
		},
		"custom": {
			"button-modal": {
				"backdrop-background-color": "rgba(23, 25, 28, 0.7)",
				"backdrop-blur": "16px",
				"background-color": "var(--wp--preset--color--white)",
				"border-color": "var(--wp--preset--color--neutral-400)",
				"border-radius": "5px",
				"border-style": "solid",
				"border-width": "1px",
				"color": "var(--wp--preset--color--neutral-0)",
				"heading-font-size": "var(--wp--preset--font-size--x-large)",
				"heading-font-weight": "700",
				"max-width": "740px",
				"padding-x": "min(40px, 5vw)",
				"padding-y": "min(32px, 5vw)"
			},
			"fontWeight": {
				"black": 900,
				"bold": 700,
				"extra-bold": 800,
				"extra-light": 200,
				"light": 300,
				"medium": 500,
				"regular": 425,
				"semi-bold": 600,
				"thin": 100
			},
			"lineHeight": {
				"body": 1.3999999999999999,
				"loose": 1.625,
				"none": 1,
				"relaxed": 1.5,
				"snug": 1.3,
				"tight": 1.1
			},
			"submenu": {
				"container": {
					"box-shadow": "1px 10px 10px rgba(0, 0, 0, 0.2)"
				}
			},
			"team-member-card": {
				"name-color": "var(--wp--preset--color--secondary-100)"
			}
		},
		"layout": {
			"contentSize": "890px",
			"wideSize": "1360px"
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{
					"name": "Subtile",
					"shadow": "0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06)",
					"slug": "subtile"
				},
				{
					"name": "Outlined",
					"shadow": "6px 6px 0px -3px rgba(255, 255, 255, 1), 6px 6px rgba(0, 0, 0, 1)",
					"slug": "outlined"
				},
				{
					"name": "Standard",
					"shadow": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)",
					"slug": "standard"
				},
				{
					"name": "Float",
					"shadow": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05)",
					"slug": "float"
				},
				{
					"name": "Close",
					"shadow": "0 5px 5px 0 rgba(0, 0, 0, 0.25)",
					"slug": "close"
				},
				{
					"name": "Deep",
					"shadow": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04)",
					"slug": "deep"
				}
			]
		},
		"spacing": {
			"blockGap": true,
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "Tiny",
					"size": "10px",
					"slug": "tiny"
				},
				{
					"name": "X-Small",
					"size": "20px",
					"slug": "x-small"
				},
				{
					"name": "Small",
					"size": "30px",
					"slug": "small"
				},
				{
					"name": "Regular",
					"size": "clamp(24px, 5vw, 32px)",
					"slug": "regular"
				},
				{
					"name": "Large",
					"size": "clamp(32px, 7vw, 48px)",
					"slug": "large"
				},
				{
					"name": "X-Large",
					"size": "clamp(50px, 7vw, 90px)",
					"slug": "x-large"
				},
				{
					"name": "XX-Large",
					"size": "clamp(70px, 10vw, 140px)",
					"slug": "xx-large"
				}
			],
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"dropCap": false,
			"fluid": true,
			"fontFamilies": [
				{
					"fontFace": [
						{
							"fontDisplay": "swap",
							"fontFamily": "Roboto",
							"fontStyle": "normal",
							"fontWeight": "100 900",
							"src": [
								"file:./assets/fonts/roboto/Roboto-VariableFont_wdth,wght.woff2"
							]
						}
					],
					"fontFamily": "Roboto, sans-serif",
					"name": "Roboto",
					"slug": "primary"
				}
			],
			"fontSizes": [
				{
					"fluid": {
						"max": "0.88rem",
						"min": "0.825rem"
					},
					"name": "Extra Small",
					"size": "0.88rem",
					"slug": "x-small"
				},
				{
					"fluid": {
						"max": "0.95rem",
						"min": "0.88rem"
					},
					"name": "Small",
					"size": "0.95rem",
					"slug": "small"
				},
				{
					"fluid": {
						"max": "1.05rem",
						"min": "1rem"
					},
					"name": "Base",
					"size": "1.05rem",
					"slug": "base"
				},
				{
					"fluid": {
						"max": "1.25rem",
						"min": "1.2rem"
					},
					"name": "Medium",
					"size": "1.25rem",
					"slug": "medium"
				},
				{
					"fluid": {
						"max": "1.55rem",
						"min": "1.4rem"
					},
					"name": "Large",
					"size": "1.5rem",
					"slug": "large"
				},
				{
					"fluid": {
						"max": "2.25rem",
						"min": "1.875rem"
					},
					"name": "Extra Large",
					"size": "2.25rem",
					"slug": "x-large"
				},
				{
					"fluid": {
						"max": "3.3125rem",
						"min": "3rem"
					},
					"name": "Extra Extra Large",
					"size": "3.3125rem",
					"slug": "xx-large"
				}
			],
			"fontWeight": true,
			"letterSpacing": true,
			"textDecoration": true,
			"textTransform": true,
			"writingMode": true
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"blocks": {
			"core/accordion": {
				"css": "& .wp-block-accordion-panel-is-layout-flow { margin-block-start: 0 !important; }",
				"spacing": {
					"blockGap": "0"
				}
			},
			"core/accordion-heading": {
				"color": {
					"text": "var(--wp--preset--color--neutral-100)"
				},
				"css": "& .wp-block-accordion-heading__toggle-icon { color: var(--wp--preset--color--primary-100); }"
			},
			"core/accordion-item": {
				"border": {
					"bottom": {
						"color": "var(--wp--preset--color--neutral-400)",
						"style": "solid",
						"width": "1px"
					}
				}
			},
			"core/accordion-panel": {
				"spacing": {
					"blockGap": "var(--wp--preset--spacing--regular)",
					"padding": {
						"bottom": "var(--wp--preset--spacing--x-small)"
					}
				}
			},
			"core/avatar": {
				"border": {
					"radius": {
						"bottomLeft": "999px",
						"bottomRight": "999px",
						"topLeft": "999px",
						"topRight": "999px"
					}
				}
			},
			"core/group": {
				"css": "&.is-linked { position: relative; } &.is-linked:not(.has-child-selected) :where(.wp-block-group__link) { content: ''; inset: 0; position: absolute; z-index: 10; } "
			},
			"core/image": {
				"variations": {
					"rounded": {
						"border": {
							"radius": "5px"
						}
					}
				}
			},
			"core/list": {
				"spacing": {
					"margin": {
						"left": "0",
						"right": "0"
					},
					"padding": {
						"left": "var(--wp--preset--spacing--small)",
						"right": "0"
					}
				}
			},
			"core/navigation": {
				"typography": {
					"fontWeight": "var(--wp--custom--font-weight--bold)"
				}
			},
			"core/post-author-name": {
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"core/post-excerpt": {
				"css": "& .wp-block-post-excerpt__more-text { margin-top: 1rem !important; }"
			},
			"core/query-pagination": {
				"css": ".wp-block-query-pagination-is-layout-flex { column-gap: 0.5rem; }",
				"elements": {
					"link": {
						":hover": {
							"color": {
								"background": "var(--wp--preset--color--primary)",
								"text": "var(--wp--preset--color--grey-700)"
							}
						},
						"border": {
							"color": "var(--wp--preset--color--grey-300)",
							"style": "solid",
							"width": "1px"
						},
						"color": {
							"background": "var(--wp--preset--color--white)",
							"text": "var(--wp--preset--color--grey-700)"
						},
						"spacing": {
							"padding": {
								"bottom": "0.5rem",
								"left": "1rem",
								"right": "1rem",
								"top": "0.5rem"
							}
						},
						"typography": {
							"fontSize": "var(--wp--preset--font-size--small)",
							"fontWeight": "700",
							"textDecoration": "none"
						}
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "700"
				}
			},
			"core/separator": {
				"border": {
					"color": "currentColor",
					"style": "solid",
					"width": "0 0 1px 0"
				},
				"color": {
					"text": "var(--wp--preset--color--accent-100)"
				},
				"css": "& {width: 100%;} &.is-style-wide { width: 100%; }"
			},
			"core/site-title": {
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--primary)"
						}
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontWeight": "700"
				}
			},
			"core/template-part": {
				"spacing": {
					"margin": {
						"top": "0px !important"
					}
				}
			}
		},
		"color": {
			"background": "var(--wp--preset--color--white)",
			"text": "var(--wp--preset--color--neutral-0)"
		},
		"css": "a { transition: color 0.3s ease-in-out; } .scrim { background-color: var(--wp--custom--popup--overlay--background) !important; } .close-button { fill: var(--wp--preset--color--white) !important; } footer.wp-block-template-part .wp-block-button__link:hover {background-color: var(--wp--preset--color--grey-700) !important;}",
		"elements": {
			"button": {
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--primary)",
						"text": "var(--wp--preset--color--white)"
					}
				},
				"border": {
					"radius": "5px"
				},
				"color": {
					"background": "var(--wp--preset--color--primary-100)",
					"text": "var(--wp--preset--color--white)"
				},
				"css": "& .wp-icon-inline { background-color: currentColor; display: inline-flex; height: 150px; mask-image: var(--icon-url); mask-position: center; mask-repeat: no-repeat; mask-size: contain; object-position: -9999px -9999px; vertical-align: middle; width: 150px; }",
				"spacing": {
					"padding": {
						"bottom": "1rem",
						"left": "2rem",
						"right": "2rem",
						"top": "1rem"
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--primary)",
					"fontSize": "1.125rem",
					"fontWeight": "var(--wp--custom--font-weight--medium)",
					"lineHeight": "var(--wp--custom--line-height--none)"
				}
			},
			"caption": {
				"color": {
					"background": "transparent",
					"text": "var(--wp--preset--color--neutral-100)"
				},
				"spacing": {
					"margin": {
						"bottom": "0",
						"top": "var(--wp--preset--spacing--x-small)"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontStyle": "italic",
					"fontWeight": "400",
					"lineHeight": "1.5"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"fontWeight": "var(--wp--custom--font-weight--light)",
					"lineHeight": "var(--wp--custom--line-height--tight)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontWeight": "var(--wp--custom--font-weight--medium)",
					"lineHeight": "var(--wp--custom--line-height--snug)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "var(--wp--custom--font-weight--semi-bold)",
					"lineHeight": "var(--wp--custom--line-height--relaxed)"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontWeight": "var(--wp--custom--font-weight--semi-bold)",
					"lineHeight": "var(--wp--custom--line-height--snug)"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontWeight": "var(--wp--custom--font-weight--bold)",
					"lineHeight": "var(--wp--custom--line-height--snug)"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "var(--wp--custom--font-weight--extra-bold)",
					"lineHeight": "var(--wp--custom--line-height--snug)"
				}
			},
			"heading": {
				"color": {
					"text": "var(--wp--preset--color--neutral-0)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--primary)"
				}
			},
			"link": {
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--primary)"
					},
					"typography": {
						"textDecoration": "none"
					}
				},
				"color": {
					"text": "var(--wp--preset--color--primary-100)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--primary)"
				}
			},
			"textInput": {
				"border": {
					"color": "var(--wp--preset--color--grey-400)",
					"radius": "0px",
					"style": "solid",
					"width": "1px"
				},
				"color": {
					"background": "var(--wp--preset--color--white)",
					"text": "var(--wp--preset--color--neutral-0)"
				},
				"shadow": "none",
				"spacing": {
					"padding": {
						"bottom": "0.75rem",
						"left": "1rem",
						"right": "1rem",
						"top": "0.75rem"
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--primary)",
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "var(--wp--custom--font-weight--regular)",
					"lineHeight": "var(--wp--custom--line-height--relaxed)"
				}
			}
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--regular)",
			"padding": {
				"bottom": "0",
				"left": "var(--wp--preset--spacing--large)",
				"right": "var(--wp--preset--spacing--large)",
				"top": "0"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--primary)",
			"fontSize": "var(--wp--preset--font-size--base)",
			"fontWeight": "var(--wp--preset--font-weight--regular)",
			"lineHeight": "var(--wp--custom--line-height--relaxed)"
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header"
		},
		{
			"area": "footer",
			"name": "footer"
		},
		{
			"area": "uncategorized",
			"name": "sidebar",
			"title": "Sidebar"
		}
	]
}
